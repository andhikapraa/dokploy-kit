{
  "name": "dokploy-mcp",
  "version": "1.0.0",
  "description": "MCP server for managing Dokploy infrastructure via API",
  "main": "src/index.js",
  "bin": {
    "dokploy-mcp": "src/index.js",
    "dokploy": "src/cli.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "cli": "node src/cli.js",
    "test": "node test/run-tests.js && node test/run-cli-tests.js",
